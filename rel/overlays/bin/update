#!/usr/bin/env bash
#
# Hostctl in-place updater.
#
# This script must be run as root. During normal operation it is invoked via
# "sudo -n /opt/hostctl/bin/update" by the hostctl service user, made possible
# by the sudoers rule installed at /etc/sudoers.d/hostctl-update.
#
# Environment variable overrides (for non-standard deployments):
#   HOSTCTL_SOURCE_DIR    source tree root  (default: /usr/local/src/hostctl)
#   HOSTCTL_APP_DIR       release directory (default: /opt/hostctl)
#   HOSTCTL_BRANCH        git branch to pull (default: main)

set -euo pipefail

APP_NAME="hostctl"
SOURCE_DIR="${HOSTCTL_SOURCE_DIR:-/usr/local/src/hostctl}"
APP_DIR="${HOSTCTL_APP_DIR:-/opt/hostctl}"
SERVICE_USER="${HOSTCTL_SERVICE_USER:-hostctl}"
BRANCH="${HOSTCTL_BRANCH:-main}"
ENV_FILE="/etc/$APP_NAME/env"

step() { echo ""; echo "==> $*"; }
info() { echo "    $*"; }
ok()   { echo "    [done]"; }

# ── 1/5  Fetch ──────────────────────────────────────────────────────────────
step "1/3  Fetching latest source"

[[ -d "$SOURCE_DIR/.git" ]] \
  || { echo "error: source directory not found: $SOURCE_DIR"; exit 1; }

git -C "$SOURCE_DIR" fetch --quiet --tags origin "$BRANCH"
git -C "$SOURCE_DIR" reset --hard "origin/$BRANCH" --quiet
info "branch: $BRANCH @ $(git -C "$SOURCE_DIR" rev-parse --short HEAD)"

# Resolve the version tag for this commit so the running app can report it.
# Prefer an exact tag on HEAD; fall back to "describe" output (e.g. v0.1.0-α+build.2-3-gabcdef).
VERSION_TAG=$(git -C "$SOURCE_DIR" describe --tags --exact-match HEAD 2>/dev/null \
  || git -C "$SOURCE_DIR" describe --tags 2>/dev/null \
  || echo "")
if [[ -n "$VERSION_TAG" ]]; then
  echo "$VERSION_TAG" > "$SOURCE_DIR/priv/VERSION"
  info "version: $VERSION_TAG"
fi

# Record the commit SHA so the updater can compare against the remote branch.
COMMIT_SHA=$(git -C "$SOURCE_DIR" rev-parse HEAD 2>/dev/null || echo "")
if [[ -n "$COMMIT_SHA" ]]; then
  echo "$COMMIT_SHA" > "$SOURCE_DIR/priv/COMMIT"
  info "commit: ${COMMIT_SHA:0:8}"
fi
ok

# ── 2/5  Build ──────────────────────────────────────────────────────────────
step "2/3  Building release (this may take a few minutes)"

cd "$SOURCE_DIR"
export HOME=/root
export MIX_ENV=prod

mix deps.get --only prod
mix deps.compile mime --force
mix assets.deploy
mix compile
mix release --overwrite
ok

# ── 3/3  Schedule install, migrate & restart ────────────────────────────────
step "3/3  Scheduling install, migrate & restart"

# We cannot stop the service from within its own systemd cgroup — the kernel
# would kill this script along with the rest of the cgroup. Instead, we write
# the destructive steps into a small script and hand it off to a detached
# transient systemd unit that lives outside the hostctl cgroup.
#
# /run is a tmpfs visible to all processes (unlike PrivateTmp=/tmp) so the
# script file is reachable by the new unit.

HANDOFF_SCRIPT="/var/log/hostctl/update-install.sh"
HANDOFF_LOG="/var/log/hostctl/update-install.log"

mkdir -p "$(dirname "$HANDOFF_SCRIPT")"
mkdir -p "$(dirname "$HANDOFF_LOG")"
touch "$HANDOFF_LOG"

# Write the handoff script without a heredoc to avoid delimiter issues.
# IMPORTANT: variable assignments must come before any line that references
# them (exec, echo, etc.) because set -euo pipefail treats unbound variables
# as fatal errors.
printf '%s\n' '#!/bin/bash' \
  'set -euo pipefail' \
  "APP_NAME=${APP_NAME}" \
  "SOURCE_DIR=${SOURCE_DIR}" \
  "APP_DIR=${APP_DIR}" \
  "SERVICE_USER=${SERVICE_USER}" \
  "ENV_FILE=${ENV_FILE}" \
  "HANDOFF_LOG=${HANDOFF_LOG}" \
  "VERSION_TAG=${VERSION_TAG}" \
  "COMMIT_SHA=${COMMIT_SHA}" \
  'exec >> "$HANDOFF_LOG" 2>&1' \
  'echo "[$(date -u +%FT%TZ)] hostctl update-install handoff started"' \
  'sleep 3' \
  'systemctl stop "$APP_NAME" || true' \
  'cp -r "$SOURCE_DIR/_build/prod/rel/$APP_NAME/." "$APP_DIR/"' \
  'chown -R "$SERVICE_USER:$SERVICE_USER" "$APP_DIR"' \
  'if [[ -n "$VERSION_TAG" ]]; then echo "$VERSION_TAG" > "/etc/$APP_NAME/version"; fi' \
  'if [[ -n "$COMMIT_SHA" ]]; then echo "$COMMIT_SHA" > "/etc/$APP_NAME/commit"; fi' \
  'ENV_VARS=$(grep -v "^#" "$ENV_FILE" | grep -v "^[[:space:]]*$" | xargs)' \
  'sudo -u "$SERVICE_USER" env $ENV_VARS "$APP_DIR/bin/migrate"' \
  'ENV_FILE="$ENV_FILE" APP_NAME="$APP_NAME" "$APP_DIR/bin/post_deploy"' \
  'systemctl start "$APP_NAME"' \
  'echo "[$(date -u +%FT%TZ)] hostctl update-install handoff complete"' \
  'rm -f "$0"' \
  > "$HANDOFF_SCRIPT"
chmod 700 "$HANDOFF_SCRIPT"

# Clear any stale failed unit from a previous update attempt; systemd-run
# will refuse to create a new unit if one of the same name already exists.
systemctl reset-failed hostctl-update-install 2>/dev/null || true

# --slice=system.slice  — ensures the unit is outside the hostctl service
#                         cgroup so stopping hostctl doesn't kill this unit.
# --collect             — auto-cleans the unit after it finishes so the name
#                         is free for the next update without reset-failed.
systemd-run --no-block \
  --unit=hostctl-update-install \
  --slice=system.slice \
  --collect \
  --description="Hostctl: install release, migrate, restart" \
  /bin/bash "$HANDOFF_SCRIPT"

info "Service is stopping to swap the release — migrations will run, then it restarts."
info "Your browser will reconnect automatically in ~30 seconds."
info "Handoff log: $HANDOFF_LOG"
ok

echo "=== Update queued — service will restart momentarily ==="
