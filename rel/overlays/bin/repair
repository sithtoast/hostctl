#!/usr/bin/env bash
#
# hostctl repair — Fix permissions, sudoers, and systemd on an existing install.
#
# Must be run as root:
#   sudo /opt/hostctl/bin/repair
#
# Safe to run multiple times; every step is idempotent. Use after upgrades or
# whenever the panel reports sudo/permission errors (e.g. feature installation
# failing with "unable to open /run/sudo/ts" or "a terminal is required").
#
# What it checks and fixes:
#   1. Service user existence
#   2. Directory ownership & permissions (webroot, logs, nginx, SSL, certbot)
#   3. Sudoers rules (update, nginx, feature management)
#   4. Systemd unit ReadWritePaths (ensures /run/sudo is writable)
#   5. Env file permissions
#   6. Verifies passwordless sudo, reloads & restarts if changes were made

set -euo pipefail

# --- Defaults (match install.sh) ----------------------------------------------
APP_NAME="hostctl"
APP_DIR="${HOSTCTL_APP_DIR:-/opt/hostctl}"
SERVICE_USER="hostctl"
SERVICE_FILE="/etc/systemd/system/$APP_NAME.service"
ENV_FILE="/etc/$APP_NAME/env"
SOURCE_DIR="${HOSTCTL_SOURCE_DIR:-/usr/local/src/$APP_NAME}"

# --- Colours ------------------------------------------------------------------
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

ok()   { echo -e "  ${GREEN}✓${NC} $*"; }
fix()  { echo -e "  ${YELLOW}⟳${NC} $*"; }
err()  { echo -e "  ${RED}✗${NC} $*"; }
head() { echo -e "\n${BOLD}$*${NC}"; }

FIXED=0

# Must run as root
[[ $EUID -eq 0 ]] || { echo -e "${RED}Error:${NC} This script must be run as root."; exit 1; }

echo -e "${BOLD}hostctl repair — checking and fixing installation${NC}"
echo "──────────────────────────────────────────────────"

# =============================================================================
# 1. Service user
# =============================================================================
head "1. Service user"

if id "$SERVICE_USER" &>/dev/null; then
  ok "User '$SERVICE_USER' exists"
else
  err "User '$SERVICE_USER' does not exist — cannot continue"
  exit 1
fi

# =============================================================================
# 2. Directory ownership & permissions
# =============================================================================
head "2. Directories"

ensure_dir() {
  local dir="$1" owner="$2" mode="$3" label="$4"
  if [[ ! -d "$dir" ]]; then
    mkdir -p "$dir"
    fix "Created $dir"
    FIXED=$((FIXED + 1))
  fi
  local cur_owner cur_mode
  cur_owner="$(stat -c '%U:%G' "$dir" 2>/dev/null)"
  cur_mode="$(stat -c '%a' "$dir" 2>/dev/null)"
  if [[ "$cur_owner" != "$owner" ]]; then
    chown "$owner" "$dir"
    fix "$label: ownership → $owner"
    FIXED=$((FIXED + 1))
  fi
  if [[ "$cur_mode" != "$mode" ]]; then
    chmod "$mode" "$dir"
    fix "$label: mode → $mode"
    FIXED=$((FIXED + 1))
  fi
  ok "$label ($dir)"
}

ensure_dir "$APP_DIR"                         "root:$SERVICE_USER" "755" "App directory"
ensure_dir "/var/log/$APP_NAME"               "root:$SERVICE_USER" "775" "Log directory"
ensure_dir "/var/www"                          "root:$SERVICE_USER" "775" "Webroot"
ensure_dir "/etc/$APP_NAME"                   "root:$SERVICE_USER" "750" "Config directory"

if command -v nginx &>/dev/null; then
  ensure_dir "/etc/nginx/sites-available"     "root:$SERVICE_USER" "775" "Nginx sites-available"
  ensure_dir "/etc/nginx/sites-enabled"       "root:$SERVICE_USER" "775" "Nginx sites-enabled"
  ensure_dir "/etc/ssl/hostctl"               "root:$SERVICE_USER" "750" "SSL cert directory"
fi

LE_DIR="/var/lib/hostctl/letsencrypt"
if [[ -d "$LE_DIR" ]] || command -v certbot &>/dev/null; then
  for d in "$LE_DIR" "$LE_DIR/work" "$LE_DIR/logs"; do
    mkdir -p "$d"
  done
  chown -R "$SERVICE_USER:$SERVICE_USER" "$LE_DIR"
  chmod 750 "$LE_DIR"
  ok "Certbot data directory ($LE_DIR)"
fi

# =============================================================================
# 3. Sudoers rules
# =============================================================================
head "3. Sudoers rules"

ensure_sudoers() {
  local file="$1" label="$2" content="$3"
  if [[ -f "$file" ]]; then
    local existing
    existing="$(cat "$file")"
    if [[ "$existing" == "$content" ]]; then
      ok "$label (unchanged)"
      return
    fi
  fi
  echo "$content" > "$file"
  chmod 440 "$file"
  if visudo -cf "$file" >/dev/null 2>&1; then
    fix "$label → written"
    FIXED=$((FIXED + 1))
  else
    err "$label — syntax check failed, removing"
    rm -f "$file"
  fi
}

# Update script
if [[ -x "$APP_DIR/bin/update" ]]; then
  ensure_sudoers "/etc/sudoers.d/hostctl-update" "Update script" \
    "$SERVICE_USER ALL=(root) NOPASSWD: $APP_DIR/bin/update"
fi

# Nginx reload
if command -v nginx &>/dev/null; then
  ensure_sudoers "/etc/sudoers.d/hostctl-nginx" "Nginx reload" \
    "$SERVICE_USER ALL=(root) NOPASSWD: /usr/bin/systemctl reload nginx"
fi

# Feature management (apt-get, systemctl, vsftpd config paths, etc.)
FEATURES_CONTENT="$SERVICE_USER ALL=(root) NOPASSWD: /usr/bin/true
$SERVICE_USER ALL=(root) NOPASSWD: /usr/bin/systemd-run *"

ensure_sudoers "/etc/sudoers.d/hostctl-features" "Feature management" "$FEATURES_CONTENT"

# =============================================================================
# 4. Systemd unit — ensure ReadWritePaths includes /run/sudo
# =============================================================================
head "4. Systemd service"

REQUIRED_RW_PATHS="$APP_DIR $SOURCE_DIR /var/log/$APP_NAME /var/www /etc/nginx/sites-available /etc/nginx/sites-enabled /etc/ssl/hostctl /var/lib/hostctl /tmp /run/sudo /var/cache/apt /var/lib/apt /var/lib/dpkg"

if [[ -f "$SERVICE_FILE" ]]; then
  # Check if ReadWritePaths includes all required paths
  if grep -q '^ReadWritePaths=' "$SERVICE_FILE"; then
    current_rw="$(grep '^ReadWritePaths=' "$SERVICE_FILE" | head -1)"
    rw_ok=true
    for rw_path in /run/sudo /var/cache/apt /var/lib/apt /var/lib/dpkg; do
      if ! echo "$current_rw" | grep -q "$rw_path"; then
        rw_ok=false
        break
      fi
    done
    if $rw_ok; then
      ok "ReadWritePaths includes all required paths"
    else
      sed -i 's|^ReadWritePaths=.*|'"ReadWritePaths=$REQUIRED_RW_PATHS"'|' "$SERVICE_FILE"
      fix "ReadWritePaths → updated with all required paths"
      FIXED=$((FIXED + 1))
    fi
  else
    # No ReadWritePaths — add it after ProtectSystem
    if grep -q '^\[Service\]' "$SERVICE_FILE"; then
      sed -i '/^ProtectSystem=/a ReadWritePaths='"$REQUIRED_RW_PATHS" "$SERVICE_FILE"
      fix "ReadWritePaths → added to service unit"
      FIXED=$((FIXED + 1))
    else
      err "Could not locate [Service] section in $SERVICE_FILE"
    fi
  fi

  if grep -q '^ProtectSystem=strict' "$SERVICE_FILE"; then
    ok "ProtectSystem=strict"
  elif grep -q '^ProtectSystem=' "$SERVICE_FILE"; then
    sed -i 's/^ProtectSystem=.*/ProtectSystem=strict/' "$SERVICE_FILE"
    fix "ProtectSystem → set to strict"
    FIXED=$((FIXED + 1))
  fi

  if grep -q '^PrivateTmp=true' "$SERVICE_FILE"; then
    ok "PrivateTmp=true"
  fi

  # Ensure ExecStartPre creates /run/sudo/ts (needed for sudo under ProtectSystem=strict)
  if grep -q 'ExecStartPre=.*mkdir.*run/sudo' "$SERVICE_FILE"; then
    ok "ExecStartPre creates /run/sudo/ts"
  else
    sed -i '/^ExecStart=/i ExecStartPre=+/usr/bin/mkdir -p /run/sudo/ts' "$SERVICE_FILE"
    fix "ExecStartPre → added /run/sudo/ts creation"
    FIXED=$((FIXED + 1))
  fi
else
  err "Service file not found at $SERVICE_FILE"
  err "Run install.sh to create it, or create it manually."
fi

# =============================================================================
# 5. Env file permissions
# =============================================================================
head "5. Environment file"

if [[ -f "$ENV_FILE" ]]; then
  cur_owner="$(stat -c '%U:%G' "$ENV_FILE" 2>/dev/null)"
  cur_mode="$(stat -c '%a' "$ENV_FILE" 2>/dev/null)"
  changed=false
  if [[ "$cur_owner" != "root:$SERVICE_USER" ]]; then
    chown "root:$SERVICE_USER" "$ENV_FILE"
    changed=true
  fi
  if [[ "$cur_mode" != "640" ]]; then
    chmod 640 "$ENV_FILE"
    changed=true
  fi
  if [[ "$changed" == true ]]; then
    fix "Env file permissions corrected"
    FIXED=$((FIXED + 1))
  fi
  ok "Env file ($ENV_FILE)"
else
  err "Env file not found at $ENV_FILE"
fi

# =============================================================================
# 6. Verify sudo works for the service user
# =============================================================================
head "6. Sudo verification"

if sudo -u "$SERVICE_USER" sudo -n /usr/bin/true 2>/dev/null; then
  ok "Service user can run sudo without a password"
else
  err "Service user still cannot run passwordless sudo"
  err "Check /etc/sudoers.d/hostctl-* files and ensure /run/sudo is writable"
fi

# =============================================================================
# 7. Apache / webmail (Roundcube, SnappyMail)
# =============================================================================
head "7. Apache webmail proxy"

if command -v apache2 &>/dev/null; then
  # Ensure Apache listens on 127.0.0.1:8080 only (Phoenix owns port 80)
  PORTS_CONF="/etc/apache2/ports.conf"
  DESIRED_PORTS="Listen 127.0.0.1:8080"
  if [[ -f "$PORTS_CONF" ]]; then
    current_ports="$(cat "$PORTS_CONF")"
    if echo "$current_ports" | grep -qE '^\s*Listen\s+(0\.0\.0\.0:)?80\b'; then
      echo "$DESIRED_PORTS" > "$PORTS_CONF"
      fix "ports.conf → 127.0.0.1:8080 (was binding to port 80)"
      FIXED=$((FIXED + 1))
    elif ! echo "$current_ports" | grep -q '127\.0\.0\.1:8080'; then
      echo "$DESIRED_PORTS" > "$PORTS_CONF"
      fix "ports.conf → 127.0.0.1:8080"
      FIXED=$((FIXED + 1))
    else
      ok "ports.conf already set to 127.0.0.1:8080"
    fi
  fi

  # Ensure ServerName is set to suppress warnings
  SN_CONF="/etc/apache2/conf-available/servername.conf"
  if [[ ! -f "$SN_CONF" ]] || ! grep -q 'ServerName' "$SN_CONF"; then
    echo "ServerName localhost" > "$SN_CONF"
    a2enconf -q servername 2>/dev/null || true
    fix "ServerName → localhost"
    FIXED=$((FIXED + 1))
  else
    ok "ServerName configured"
  fi

  # Restart Apache if it exists but isn't running or was reconfigured
  if ! systemctl is-active --quiet apache2; then
    systemctl enable --now apache2 2>/dev/null && fix "Apache started" || err "Apache failed to start"
    FIXED=$((FIXED + 1))
  else
    ok "Apache is running"
  fi

  # Fix Roundcube SQLite config if roundcube is installed but using MySQL
  if dpkg -l roundcube-core &>/dev/null 2>&1; then
    RC_CONF="/etc/roundcube/config.inc.php"
    if [[ -f "$RC_CONF" ]] && grep -q 'mysql\|pgsql' "$RC_CONF" 2>/dev/null; then
      fix "Roundcube config references MySQL/PostgreSQL — rewriting for SQLite"
      mkdir -p /var/lib/roundcube
      chown www-data:www-data /var/lib/roundcube

      # Install SQLite packages if missing
      if ! dpkg -l roundcube-sqlite3 &>/dev/null 2>&1; then
        DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends roundcube-sqlite3 php-sqlite3 >/dev/null 2>&1
        fix "Installed roundcube-sqlite3 and php-sqlite3"
      fi

      cat > "$RC_CONF" <<'RCEOF'
<?php
$config['db_dsnw'] = 'sqlite:////var/lib/roundcube/roundcube.db?mode=0640';
$config['imap_host'] = 'localhost:143';
$config['smtp_host'] = 'localhost:587';
$config['smtp_auth_type'] = 'LOGIN';
$config['product_name'] = 'hostctl Webmail';
$config['plugins'] = ['archive', 'zipdownload'];
$config['skin'] = 'elastic';
RCEOF
      FIXED=$((FIXED + 1))
    else
      ok "Roundcube config"
    fi
  fi
else
  ok "Apache not installed — skipping"
fi

# =============================================================================
# 8. Reload & restart
# =============================================================================
head "8. Apply changes"

if [[ $FIXED -gt 0 ]]; then
  systemctl daemon-reload
  fix "systemd daemon reloaded"

  if systemctl is-active --quiet apache2 2>/dev/null; then
    systemctl restart apache2
    fix "Apache restarted"
  fi

  if systemctl is-active --quiet "$APP_NAME"; then
    systemctl restart "$APP_NAME"
    fix "Service restarted"
  fi
  echo ""
  echo -e "${GREEN}${BOLD}Repair complete — $FIXED issue(s) fixed.${NC}"
else
  echo ""
  echo -e "${GREEN}${BOLD}Everything looks good — no changes needed.${NC}"
fi
